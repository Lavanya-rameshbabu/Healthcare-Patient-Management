@model List<HealthcareApp1.Models.Patient>

@{
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 5;
    int count = ((page - 1) * pageSize) + 1;
}

<div class="container mt-4">

    <h2 class="mb-4 text-center">Patient List</h2>
    <form method="get" class="mb-3 text-center">

    <input type="text" name="search"
           value="@Context.Request.Query["search"]"
           placeholder="Search by name..."
           class="form-control w-25 d-inline" />

        @{
            var selectedGender = Context.Request.Query["gender"].ToString();
        }
           <select name="gender" class="form-select w-25 d-inline ms-2">

            <option value="">All</option>

            @if (selectedGender == "Male")
            {
                <option value="Male" selected>Male</option>
            }
            else
            {
                <option value="Male">Male</option>
            }

            @if (selectedGender == "Female")
            {
                <option value="Female" selected>Female</option>
            }
            else
            {
                <option value="Female">Female</option>
            }

        </select>

    <button type="submit" class="btn btn-primary ms-2">Filter</button>

    <a href="/Patient/Index" class="btn btn-secondary ms-2">Reset</a>

</form>
    <p class="text-end">
        Total Patients: <strong>@ViewBag.TotalRecords</strong>
    </p>
    <table class="table table-bordered table-striped table-hover shadow">
           <thead class="table-dark text-center">
            <tr>
                <th>S.No</th>
                <th>Name</th>
                <th>Gender</th>
                <th>Phone</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model)
            {
                <tr class="text-center">
                    <td>@count</td>
                    <td>@p.FirstName @p.LastName</td>
                    <td>@p.Gender</td>
                    <td>@p.Phone</td>
                    <td>@p.Email</td>
                    <td>
                        <a href="/Patient/Edit/@p.PatientID" class="btn btn-sm btn-warning me-2">Edit ✏️</a>

                        <a href="/Patient/Delete/@p.PatientID"
                           class="btn btn-sm btn-danger"
                           onclick="return confirm('Are you sure you want to delete this patient?');">
                            Delete 🗑️
                        </a>
                    </td>
                </tr>

                count++;
            }
        </tbody>

    </table>
    @{
        int totalRecords = ViewBag.TotalRecords ?? 0;
        int currentPage = ViewBag.Page ?? 1;

        int totalPages = (int)Math.Ceiling((double)totalRecords / pageSize);
    }

    <div class="text-center mt-3">

        @for (int i = 1; i <= totalPages; i++)
        {
            <a href="/Patient/Index?page=@i&search=@Context.Request.Query["search"]&gender=@Context.Request.Query["gender"]"
               class="btn @(i == currentPage ? "btn-primary" : "btn-outline-primary") me-1">
                @i
            </a>
        }

    </div>
</div>